# Project default (spec)
PORT=5000

# Optional local binding (helps on some setups)
HOST=127.0.0.1

# Supabase / Postgres
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE

# Tenancy configuration
TENANCY_BASE_DOMAIN=localhost

# Admin auth
ADMIN_KEY=dev_admin_key_change_me

# CORS
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=0

# Proxy (set when behind a proxy)
TRUST_PROXY=1

# Database connection pool configuration
# DATABASE_SSL=true   # enable SSL for managed DBs (Supabase)
# DATABASE_SSL=false  # force-disable SSL (local dev)
DATABASE_SSL=true
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONN_TIMEOUT_MS=5000
DB_KEEPALIVE_DELAY_MS=10000

# ---- Supabase Storage (file uploads) ----
# Required for deliverable file uploads and product image uploads.
# SUPABASE_URL is derived from DATABASE_URL (e.g. https://<project-id>.supabase.co)
SUPABASE_URL=https://<project-id>.supabase.co
# Service-role key (NOT the anon key) — found in Supabase → Settings → API
SUPABASE_SERVICE_KEY=eyJ...

# ---- Stripe (test mode) ----
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret from `stripe listen` CLI or Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_...
# Frontend origin used for Stripe success/cancel redirect URLs
APP_BASE_URL=http://localhost:5173
# Frontend origin used for password reset email links
FRONTEND_URL=http://localhost:5173

# ---- Fulfillment / delivery email ----
# Backend origin used for delivery link URLs (e.g. http://localhost:5051)
BACKEND_URL=http://localhost:5051
# How long delivery tokens are valid (hours, default 72)
DELIVERY_TOKEN_TTL_HOURS=72
# Email provider: "log" (prints to console) or "resend"
MAILER_PROVIDER=log
# Sender address (required for resend)
MAILER_FROM=noreply@yourdomain.com
# Resend API key (required when MAILER_PROVIDER=resend)
# RESEND_API_KEY=re_...

# ---- Custom domains ----
# Where custom domains should CNAME to (your platform's apex/proxy hostname)
PLATFORM_CNAME_TARGET=stores.yourplatform.com
# Your platform's own domain (used to distinguish custom domains from platform-hosted ones)
PLATFORM_DOMAIN=yourplatform.com

# ---- Debugging / logging ----
# Set to false in production — can expose SQL parameter values in logs
DB_LOG=0

# ---- CORS extended options ----
# Allows any localhost origin (e.g. Vite dev server on a non-standard port).
# Set to 0 in production — only CORS_ORIGIN is trusted there.
CORS_ALLOW_LOCAL_DEV=1
# Allows requests with Origin: null (file:// or sandboxed iframes).
# Set to false in production — this is almost never needed in prod.
CORS_ALLOW_NULL=0

# ---- Rate limiting ----
# Disable limiters (use in CI/tests if you want)
RL_PUBLIC_DISABLED=0
RL_CHECKOUT_DISABLED=0

# Tuning (defaults are safe)
RL_PUBLIC_WINDOW_MS=60000
RL_PUBLIC_MAX=300

RL_CHECKOUT_WINDOW_MS=60000
RL_CHECKOUT_MAX=30

